<script>
async function cargarAnomalias() {
  const cont = document.getElementById("anomalias");
  cont.innerHTML = "<p class='text-muted'>Cargando noticias...</p>";

  try {
    // Usamos rss2json como proxy para evitar CORS
    const url = "https://api.rss2json.com/v1/api.json?rss_url=https://caracol.com.co/rss/";
    const res = await fetch(url);
    const data = await res.json();

    // Mostramos máximo 5 noticias
    cont.innerHTML = "";
    items.slice(0, 5).forEach(item => {
      const card = `
        <div class="card mb-2">
          <div class="card-body">
            <h5 class="card-title">${item.title}</h5>
            <p class="card-text">${item.description}</p>
            <span class="badge bg-info">Caracol RSS</span>
          </div>
        </div>
      `;
      cont.innerHTML += card;
    });

    if (items.length === 0) {
      cont.innerHTML = "<p class='text-muted'>No hay anomalías locales en este momento.</p>";
    }

  } catch (e) {
    cont.innerHTML = "<p class='text-muted'>No se pudo cargar noticias RSS</p>";
    console.error("Error cargando RSS:", e);
  }
}

// Ejecutar al cargar la página
cargarAnomalias();

// Refrescar cada minuto
setInterval(cargarAnomalias, 60000);
</script>
